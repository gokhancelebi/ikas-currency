APP_NAME="Entegrasyonum Fiyat Senkronizasyonu Sistemi"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
# Hareketsizlikte oturum düşer (dakika)
SESSION_LIFETIME=120
# Girişten bu kadar dakika sonra zorunlu çıkış (0 = kapalı, yalnızca SESSION_LIFETIME)
SESSION_ABSOLUTE_LIFETIME=0

# Arama motorları: robots.txt + meta + bot UA engeli + X-Robots-Tag
BLOCK_SEARCH_ENGINE_BOTS=true
SITE_NOINDEX=true

# HTTP rate limit
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120          # Genel web (IP / kullanıcı)
AUTH_RATE_LIMIT_PER_MINUTE=20      # Auth POST (giriş, kayıt, şifre sıfırlama)
LOGIN_MAX_ATTEMPTS=5               # Başarısız giriş / e-posta+IP
LOGIN_DECAY_MINUTES=1              # Giriş kilidi süresi (dakika)
CRON_REFRESH_RATE_LIMIT=10         # /cron-refresh / dakika / IP
CRON_SECRET=                       # /cron-refresh?token=... (boşsa endpoint kapalı)

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Kur/sync hatalarında e-posta bildirimi
ADMIN_MAIL_NOTIFICATIONS_ENABLED=false
ADMIN_EMAIL=
# Aynı uyarı maili en fazla kaç saniyede bir (varsayılan 300 = 5 dk)
ADMIN_MAIL_THROTTLE_SECONDS=300

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# İkas sync (GraphQL price push)
IKAS_CLIENT_ID=
IKAS_CLIENT_SECRET=
IKAS_STORE_DOMAIN=https://your-store.myikas.com/
IKAS_APP_MODE=PROD
IKAS_LIVE_TESTS=false
IKAS_TEST_TAG=SYNC_TEST
IKAS_THROTTLE_SECONDS=1
# Yeni ürünlerin varsayılan maliyet birimi (sync ile panele ilk düşerken)
IKAS_DEFAULT_PRICE_TYPE=TL

# Altınkaynak kurları — https://www.altinkaynak.com/Araclar/Servisler
ALTINKAYNAK_CURRENCY_URL=https://static.altinkaynak.com/public/Currency
ALTINKAYNAK_GOLD_URL=https://static.altinkaynak.com/public/Gold

# Yeni üye kaydı (kapalıyken /register 404 döner)
REGISTRATION_ENABLED=false

# Cloudflare Turnstile (giriş, kayıt, şifremi unuttum, şifre sıfırlama)
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
